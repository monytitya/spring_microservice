{
  "id": null,
  "uid": "banking-overview",
  "title": "Banking Microservices — Overview",
  "description": "Spring Boot 3 metrics for all banking services",
  "tags": ["spring-boot", "banking", "microservices"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Services Up",
      "description": "Number of Spring Boot services currently UP",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "yellow","value": 4 },
              { "color": "green", "value": 8 }
            ]
          },
          "unit": "none"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "count(up{job=~\"customer-service|account-service|transaction-service|loan-service|card-service|api-gateway|config-server|discovery-server\"} == 1)",
          "legendFormat": "Up",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total HTTP Requests / min",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": 0 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Response Time",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 1.0  }
            ]
          },
          "unit": "s"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "sum(rate(http_server_requests_seconds_sum[1m])) / sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "avg latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "HTTP Error Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "📈 HTTP Request Rate by Service",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Requests per Second — per Service",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "rate(http_server_requests_seconds_count{job=~\"customer-service|account-service|transaction-service|loan-service|card-service|api-gateway\"}[1m])",
          "legendFormat": "{{job}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "💾 JVM Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "JVM Heap Used — per Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"customer-service|account-service|transaction-service|loan-service|card-service|api-gateway\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "JVM Threads — per Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "jvm_threads_live_threads{job=~\"customer-service|account-service|transaction-service|loan-service|card-service|api-gateway\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "🗄️ Database Connection Pools",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HikariCP Active Connections",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "hikaricp_connections_active{job=~\"customer-service|account-service|transaction-service|loan-service|card-service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "HikariCP Pending Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "hikaricp_connections_pending{job=~\"customer-service|account-service|transaction-service|loan-service|card-service\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "⚡ Kafka Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "kafka_consumer_fetch_manager_records_lag{job=~\"transaction-service\"}",
          "legendFormat": "{{topic}} [{{partition}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Kafka Records Consumed / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-banking" },
          "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total{job=~\"transaction-service\"}[1m])",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ]
    }
  ]
}

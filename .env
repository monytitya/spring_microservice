# ==================== PostgreSQL ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spring_microservice
DB_USER=postgres
DB_PASSWORD=postgres

# Internal postgres container config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# ==================== Kafka ====================
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# ==================== Service Ports ====================
CONFIG_SERVER_PORT=8888
DISCOVERY_SERVER_PORT=8761
CUSTOMER_SERVICE_PORT=8081
ACCOUNT_SERVICE_PORT=8082
TRANSACTION_SERVICE_PORT=8083
LOAN_SERVICE_PORT=8084
CARD_SERVICE_PORT=8085
API_GATEWAY_PORT=8090

# ==================== Spring ====================
SPRING_PROFILES_ACTIVE=docker

# ==================== Eureka ====================
EUREKA_INSTANCE_PREFER_IP_ADDRESS=true
EUREKA_CLIENT_REGISTER_WITH_EUREKA=true
EUREKA_CLIENT_FETCH_REGISTRY=true

# ==================== Logging ====================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_MICROSERVICE=DEBUG
